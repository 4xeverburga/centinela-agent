# Telegram
BOT_HTTP_API_TOKEN=REPLACE_ME
TELEGRAM_BOT_USER_ID=C3nt1nel_bot
TELEGRAM_BOT_DISPLAY_NAME=Centinela

# AMD GPU Droplet
DROPLET_IP=134.199.206.109
DROPLET_SSH_PRV_KEY_PATH=/home/ever/.ssh/amd_gpu_droplet

# vLLM
VLLM_BASE_URL=http://<DROPLET_IP>:8000/v1
VLLM_MODEL=google/gemma-4-31B-it

# Hugging Face (token with read access; needed to download gated weights on the droplet)
HF_TOKEN=REPLACE_ME

# Database
SQLITE_PATH=centinela.db

# Image pipeline
EMBEDDING_BACKEND=imagehash
IMAGE_JPEG_QUALITY=75
IMAGE_MAX_LONG_EDGE=1280
IMAGE_SHARPNESS_MIN=50.0
IMAGE_SIMILARITY_THRESHOLD=0.15
CLUSTERING_WINDOW_SECONDS=60

# Queue worker
WORKER_MAX_ATTEMPTS=3
WORKER_BACKOFF_BASE_SECONDS=2.0
WORKER_GRACE_PERIOD_SECONDS=15

# Project lifecycle
PROJECT_AUTO_CLOSE_HOURS=72

# HITL context window
HITL_CONTEXT_MAX_MESSAGES=5
HITL_CONTEXT_WINDOW_MINUTES=30

# Admin whitelist (comma-separated Telegram user IDs)
ADMIN_TELEGRAM_USER_IDS=REPLACE_ME

# Assistant whitelist (format: "assistant_id:admin_id,assistant_id:admin_id")
ASSISTANT_TELEGRAM_USER_IDS=

# Locale ("es" or "en")
BOT_LOCALE=es

# System version (used as part of the inspections_queue composite key)
SYSTEM_VERSION=may2026:0.1
